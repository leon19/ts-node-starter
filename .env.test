# Note: --test-isolation=none is required when using @swc-node/register with
# Node's built-in test runner. Without it, each test file runs in a child process
# where the SWC loader re-registers and fails to resolve its own module specifier.
NODE_ENV=test
NODE_OPTIONS="--enable-source-maps --import @swc-node/register/esm-register --test-isolation=none"

# If you need a global setup file, you can use the following node options:
# NODE_OPTIONS=" --enable-source-maps --import @swc-node/register/esm-register --import ./test/setup.ts"

# file: test/setup.ts
# ```ts
# import { after, before } from 'node:test';
# import chai from 'chai';
# import chaiAsPromised from 'chai-as-promised';
#
# // Extend Chai with chai-as-promised
# chai.use(chaiAsPromised);
#
# before(() => {
#   // Do something before all tests
# });
#
# after(() => {
#   // Do something after all tests
# });
# ```
